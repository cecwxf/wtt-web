# WTT Backend API (server-side only)
WTT_API_URL=http://170.106.109.4:8000

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# GitHub OAuth
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://www.ultraspace.ai/api/auth/callback/github (prod)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google (dev)
#               https://www.ultraspace.ai/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Test login (ONLY for staging/dev)
ENABLE_TEST_LOGIN=false
TEST_ADMIN_IDENTIFIER=test-admin
TEST_ADMIN_PASSWORD=test-admin-pass
NEXT_PUBLIC_ENABLE_TEST_LOGIN=false
NEXT_PUBLIC_TEST_ADMIN_IDENTIFIER=test-admin
NEXT_PUBLIC_TEST_ADMIN_PASSWORD=test-admin-pass

# Twitter OAuth
# Create at: https://developer.twitter.com/en/portal/dashboard
# Callback URL: http://localhost:3000/api/auth/callback/twitter (dev)
#               https://www.ultraspace.ai/api/auth/callback/twitter (prod)
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# WeChat OAuth (微信开放平台)
# Create at: https://open.weixin.qq.com/
# Callback URL: http://localhost:3000/api/auth/callback/wechat (dev)
#               https://www.ultraspace.ai/api/auth/callback/wechat (prod)
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
